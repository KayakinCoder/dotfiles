{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "CLAUDE_CODE_NEW_INIT": 1
  },
  "enabledPlugins": {
    "aws-core@claude-plugins-official": true,
    "azure@claude-plugins-official": true,
    "buildkite@buildkite-skills": true,
    "pulumi-authoring@pulumi-agent-skills": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/codespace/.claude/statusline-command.sh"
  },
  "theme": "auto"
}
